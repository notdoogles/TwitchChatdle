# Supabase Postgres connection string. Use the "Transaction pooler" (port 6543)
# connection string from Supabase's project settings -> Database -> Connection string,
# not the direct connection -- serverless functions need pooled connections.
DATABASE_URL=postgresql://REPLACE_WITH_SUPABASE_CONNECTION_STRING

# The Twitch channel this game serves questions from (must match what the
# ingestion worker is logging to the `messages` table).
TWITCH_CHANNEL=your_channel_name

# Display name shown in the page title and UI. Defaults to "Chatdle" if unset.
GAME_NAME=Chatdle

# Message shown when the player wins/loses a round. Defaults to
# "You won!" / "You lost!" if unset.
WINNER_MESSAGE=You won!
LOSER_MESSAGE=You lost!

# Hour of day (0-23) and IANA timezone at which the daily round resets.
# Defaults to 0 (midnight) in America/New_York if unset.
RESET_HOUR=0
RESET_TIMEZONE=America/New_York

# Max number of usernames shown in the guess box's autocomplete list. This is
# just a UX cap (a giant dropdown stops being a useful hint), not a
# performance limit -- the correct answer is always included even if the
# channel has more eligible chatters than this. Defaults to 300 if unset.
USERNAME_HINTS_LIMIT=300

# Caps on individual message length (characters) and word count considered
# eligible for a round. Guards against copypasta walls of text -- a message
# can be unique and readable but still too long to make for a fun round.
# Default to 500 characters / 60 words if unset.
MAX_MESSAGE_LENGTH=500
MAX_MESSAGE_WORDS=60
