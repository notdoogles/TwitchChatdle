# Twitch channel to listen to (without the #)
TWITCH_CHANNEL=your_channel_name

# Postgres connection string (Neon / Supabase give you this directly)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Comma-separated, case-insensitive usernames to exclude from logging.
# Good for bots (Nightbot, StreamElements, Moobot) or anyone who asked to be excluded.
EXCLUDED_USERNAMES=nightbot,streamelements,moobot,fossabot

# Optional: also skip anything that looks like a bang-command (!command args)
SKIP_COMMANDS=true
